{
    "packages": {
        "turbo/packages/core": {
            "release-type": "node"
        },
        "turbo/apps/cli": {
            "release-type": "node"
        },
        "turbo/apps/web": {
            "release-type": "node"
        },
        "turbo/apps/docs": {
            "release-type": "node"
        },
        "turbo/apps/platform": {
            "release-type": "node"
        },
        "crates/ably-subscriber": {
            "release-type": "rust"
        },
        "crates/guest-agent": {
            "release-type": "rust"
        },
        "crates/guest-common": {
            "release-type": "rust"
        },
        "crates/guest-download": {
            "release-type": "rust"
        },
        "crates/guest-init": {
            "release-type": "rust"
        },
        "crates/guest-mock-claude": {
            "release-type": "rust"
        },
        "crates/reqeast": {
            "release-type": "rust"
        },
        "crates/runner": {
            "release-type": "rust",
            "component": "runner-rs"
        },
        "crates/sandbox": {
            "release-type": "rust"
        },
        "crates/sandbox-fc": {
            "release-type": "rust"
        },
        "crates/vsock-guest": {
            "release-type": "rust"
        },
        "crates/vsock-host": {
            "release-type": "rust"
        },
        "crates/vsock-proto": {
            "release-type": "rust"
        },
        "crates/vsock-test": {
            "release-type": "rust"
        }
    },
    "plugins": [
        {
            "type": "node-workspace",
            "alwaysLinkLocal": true
        },
        {
            "type": "cargo-workspace",
            "cargoWorkspacePath": "crates"
        }
    ]
}
