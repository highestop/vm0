{
  "name": "api",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint && oxlint --type-aware -c ../../.oxlintrc.typeaware.json && eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.15"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vm0/eslint-config": "workspace:*",
    "@vm0/typescript-config": "workspace:*",
    "eslint": "^9.34.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "0.21.1",
    "tsx": "^4.19.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  }
}
