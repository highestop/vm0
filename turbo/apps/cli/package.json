{
  "name": "@vm0/cli",
  "version": "9.131.0",
  "private": true,
  "description": "CLI application",
  "repository": {
    "type": "git",
    "url": "https://github.com/vm0-ai/vm0",
    "directory": "turbo/apps/cli"
  },
  "type": "module",
  "bin": {
    "vm0": "./dist/index.js",
    "zero": "./dist/zero.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "cp package.json dist/ && pnpm json -I -f dist/package.json -e 'this.name=\"@vm0/cli\"; delete this.private; delete this.scripts; delete this.devDependencies; this.bin[\"vm0\"]=\"index.js\"; this.bin[\"zero\"]=\"zero.js\"; this.files=[\"*.js\",\"*.js.map\"]'",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint && oxlint --type-aware -c ../../.oxlintrc.typeaware.json && eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.6.0"
  },
  "devDependencies": {
    "@sentry/node": "^10.38.0",
    "@ts-rest/core": "3.53.0-rc.1",
    "@types/node": "^24.3.0",
    "@types/prompts": "^2.4.9",
    "@types/tar": "^6.1.13",
    "@vm0/core": "workspace:*",
    "@vm0/eslint-config": "workspace:*",
    "@vm0/typescript-config": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.0",
    "dotenv": "^17.2.1",
    "eslint": "^9.34.0",
    "json": "^11.0.0",
    "msw": "^2.13.2",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "0.21.1",
    "prompts": "^2.4.2",
    "tar": "^7.5.7",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "undici": "^6.24.0",
    "vitest": "^4.1.4",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  }
}
