# Environment Configuration for VM0 Platform
# Copy this file to .env.local and fill in the values
# Or run ./scripts/sync-env.sh to sync from 1Password

# =============================================================================
# Authentication (REQUIRED)
# =============================================================================
# Clerk publishable key for user authentication
# Get this from your Clerk dashboard: https://dashboard.clerk.com
# Required: Yes (app will fail to load without this)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# =============================================================================
# API Configuration (REQUIRED)
# =============================================================================
# Backend API URL for the web service
# - Development: http://localhost:3000 (special value that enables auto-detection)
# - Production: https://www.vm0.ai (set automatically in CI)
#
# When set to http://localhost:3000, the app will automatically derive the API URL
# from the current browser origin by replacing "platform" or "app" with "www" in the hostname.
# For example: https://app.vm7.ai:8443 -> https://www.vm7.ai:8443
#              (previously at platform.vm7.ai, now migrated to app.vm7.ai)
#
# Required: Yes (app will fail to load without this)
VITE_API_URL=http://localhost:3000

# =============================================================================
# Public Artifact CDN (REQUIRED)
# =============================================================================
# Public base URL for user artifacts copied and downloaded from the platform app.
# Required: Yes (artifact copy/download links fall back to /f/ without this)
PUBLIC_ARTIFACTS_BASE_URL=https://cdn.vm7.io
