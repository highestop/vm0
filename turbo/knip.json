{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/web": {
      "entry": [
        "app/**/page.{ts,tsx}",
        "app/**/layout.{ts,tsx}",
        "app/**/route.{ts,tsx}!",
        "proxy.{ts,tsx}",
        "proxy.cors.ts",
        "i18n.ts",
        "navigation.ts",
        "**/__tests__/**/*.{test,spec}.{ts,tsx}",
        "**/*.{test,spec}.{ts,tsx}",
        "src/__tests__/api-test-helpers/index.ts",
        "src/__tests__/webhook-simulators/index.ts"
      ],
      "project": [
        "**/*.{ts,tsx}!",
        "!**/__tests__/**!",
        "!**/*.{test,spec}.{ts,tsx}!",
        "!src/lib/test-endpoints/**!",
        "!src/mocks/**!"
      ],
      "ignoreDependencies": [
        "@vm0/ui",
        "e2b",
        "import-in-the-middle",
        "require-in-the-middle",
        "cpu-features"
      ],
      "ignoreBinaries": ["drizzle-kit"],
      "next": {
        "entry": ["next.config.{js,ts,mjs}"]
      }
    },
    "apps/cli": {
      "entry": [
        "src/**/__tests__/**/*.{test,spec}.ts",
        "src/**/*.{test,spec}.ts",
        "src/commands/logs/index.ts",
        "src/commands/logs/search.ts",
        "src/commands/zero/logs/index.ts",
        "src/commands/zero/logs/list.ts",
        "src/commands/zero/logs/search.ts"
      ],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@types/tar"],
      "tsup": {
        "config": ["tsup.config.ts"]
      }
    },
    "apps/api": {
      "entry": [
        "src/index.ts",
        "src/server.ts",
        "src/signals/context/hono.ts",
        "src/signals/context/wait-until.ts",
        "src/signals/external/clerk.ts",
        "src/signals/external/env.ts",
        "src/scripts/**/*.ts",
        "custom-eslint/index.ts",
        "custom-eslint/**/*.{test,spec}.ts",
        "src/**/*.{test,spec}.ts"
      ],
      "project": ["src/**/*.ts", "custom-eslint/**/*.ts"]
    },
    "apps/platform": {
      "entry": ["src/main.ts", "**/*.{test,spec}.ts?(x)"],
      "project": ["**/*.{ts,tsx}"],
      "ignore": [
        "custom-eslint/**",
        "src/views/zero-page/zero-sidebar-account.tsx",
        "src/views/zero-page/zero-sidebar-chat-list.tsx",
        "src/views/zero-page/zero-sidebar-pinned.tsx",
        "src/views/zero-page/zero-sidebar-scroll.tsx",
        "src/views/zero-page/zero-sidebar-upgrade.tsx"
      ],
      "ignoreDependencies": [
        "idb",
        "katex",
        "tailwindcss",
        "typescript-eslint",
        "@tailwindcss/typography"
      ]
    },
    "apps/host-worker": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts", "*.config.mjs"],
      "ignoreDependencies": ["eslint", "oxlint", "wrangler"],
      "ignoreBinaries": ["eslint", "oxlint", "wrangler"]
    },
    "apps/desktop": {
      "entry": [
        "forge.config.js",
        "vite.renderer.config.ts",
        "src/main.ts",
        "src/preload.ts",
        "src/vm0-computer.ts",
        "src/renderer/main.tsx",
        "src/**/*.{test,spec}.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx}", "*.{js,ts}"],
      "ignoreDependencies": [
        "@electron-forge/cli",
        "@electron-forge/maker-zip",
        "oxlint",
        "tsup"
      ],
      "ignoreBinaries": ["electron-forge", "oxlint", "tsup"]
    },
    "packages/core": {
      "entry": [
        "src/**/__tests__/**/*.{test,spec}.ts",
        "src/**/*.{test,spec}.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "packages/connectors": {
      "entry": [
        "src/**/__tests__/**/*.{test,spec}.ts",
        "src/**/*.{test,spec}.ts"
      ],
      "project": ["src/**/*.ts"],
      "ignore": ["src/firewalls/*.generated.ts"]
    },
    "packages/db": {
      "entry": [
        "src/index.ts",
        "src/**/__tests__/**/*.{test,spec}.ts",
        "src/**/*.{test,spec}.ts",
        "scripts/**/*.ts"
      ],
      "project": ["src/**/*.ts", "scripts/**/*.ts", "drizzle.config.ts"],
      "ignoreBinaries": ["drizzle-kit"]
    },
    "packages/ui": {
      "entry": [
        "src/**/__tests__/**/*.{test,spec}.{ts,tsx}",
        "src/**/*.{test,spec}.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["autoprefixer"]
    },
    "packages/eslint-config": {
      "entry": [],
      "project": ["**/*.js"]
    },
    "packages/typescript-config": {
      "entry": [],
      "project": ["*.json"],
      "ignoreUnresolved": ["next"]
    },
    "packages/proxy": {
      "entry": [],
      "project": ["**/*.{js,json}"]
    }
  },
  "ignore": [
    "**/*.d.ts",
    ".next/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "**/custom-eslint/**",
    "apps/platform/src/mocks/mock-log-detail-data.ts",
    "apps/platform/src/test/mocks/clerk-react.ts",
    "apps/platform/src/test/mocks/clerk-react-experimental.ts",
    "apps/platform/src/mocks/ably.ts",
    "apps/platform/src/mocks/idb.ts",
    "apps/cli/src/lib/utils/paginate.ts",
    "scripts/rebuild-snapshots.ts",
    "scripts/rebuild-snapshots-from-db.ts",
    "scripts/analyze-cpuprofile.mjs",
    "scripts/analyze-call-frequency.mjs",
    "scripts/analyze-batching.mjs",
    "scripts/analyze-react-renders.mjs",
    "scripts/analyze-rewind-cause.mjs",
    "scripts/analyze-rewind.mjs",
    "scripts/dump-rewind-chains.mjs"
  ],
  "ignoreDependencies": ["@commitlint/cli", "@vm0/firewalls-generator"],
  "ignoreWorkspaces": [],
  "ignoreUnresolved": ["\\.generated$"]
}
