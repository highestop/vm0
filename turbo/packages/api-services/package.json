    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@vm0/eslint-config": "workspace:*",
    "@vm0/typescript-config": "workspace:*",
    "eslint": "^9.34.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "0.21.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.6"
  }
}
