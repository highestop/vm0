{
  "name": "@vm0/api-services",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./errors": {
      "import": "./src/errors.ts",
      "types": "./src/errors.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
