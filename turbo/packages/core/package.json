{
  "name": "@vm0/core",
  "version": "8.236.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*.ts",
      "types": "./src/*.ts"
    },
    "./contracts": {
      "import": "./src/contracts/index.ts",
      "types": "./src/contracts/index.ts"
    },
    "./firewalls": {
      "import": "./src/firewalls/index.ts",
      "types": "./src/firewalls/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint && oxlint --type-aware -c ../../.oxlintrc.typeaware.json && eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@vm0/eslint-config": "workspace:*",
    "@vm0/typescript-config": "workspace:*",
    "eslint": "^9.34.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "0.21.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@vm0/api-contracts": "workspace:*",
    "yaml": "^2.8.1"
  }
}
