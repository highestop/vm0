{
  "name": "@vm0/db",
  "version": "1.18.6",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./schema/*": {
      "import": "./src/schema/*.ts",
      "types": "./src/schema/*.ts"
    },
    "./types": {
      "import": "./src/types.ts",
      "types": "./src/types.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint && oxlint --type-aware -c ../../.oxlintrc.typeaware.json && eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@vm0/api-contracts": "workspace:*",
    "@vm0/connectors": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vm0/eslint-config": "workspace:*",
    "@vm0/typescript-config": "workspace:*",
    "eslint": "^9.34.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.7"
  }
}
